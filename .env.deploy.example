# Deploy config for a small shared instance (e.g. ~5 internal testers).
# Copy to .env.deploy (gitignored), fill in real values, then:
#
#   docker compose --env-file .env.deploy up -d --build
#
# Generate the two secrets (do NOT reuse the repo's local-* defaults):
#   openssl rand -hex 32

# production makes the app REFUSE to boot on the repo's default secret/salt,
# so the two values below must be real randoms.
MCA_ENVIRONMENT=production

MCA_SESSION_SECRET=__run: openssl rand -hex 32__
MCA_USER_HASH_SALT=__run: openssl rand -hex 32__

# Token that guards the admin crime-ingest endpoint (pick any strong random).
#   openssl rand -hex 24
MCA_ADMIN_INGEST_TOKEN=__run: openssl rand -hex 24__

# Internal HTTP trial: keep false (cookies work over plain HTTP).
# Behind HTTPS (recommended even internally): set true.
MCA_SESSION_COOKIE_SECURE=false

# Personal-upload mode stays off for the trial.
MCA_PUBLIC_ENABLE_PERSONAL_UPLOADS=false

# Optional: a Socrata app token raises ingest rate limits. Leave blank otherwise.
SOCRATA_APP_TOKEN=

# The assistant calls a model gateway on the HOST. From the container, reach it via
# host.docker.internal. The host LocalAgent (default :8010) must be running.
MCA_LOCALAGENT_BASE_URL=http://host.docker.internal:8010
